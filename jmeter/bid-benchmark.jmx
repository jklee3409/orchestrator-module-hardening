<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Bid Hot Path Benchmark Rewrite">
      <stringProp name="TestPlan.comments">Measure POST /orchestrator/bid hot path only. Run this plan once per implementation using -JimplMode=redis or -JimplMode=db-lock. Run winner-heavy and loser-heavy separately using -JworkloadType. Winner-heavy expects a feed where increasing bids can succeed. Loser-heavy expects a feed already seeded with a committed highest bid greater than fixedBidAmount so most requests fail fast as too low.</stringProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments">
          <elementProp name="protocol" elementType="Argument">
            <stringProp name="Argument.name">protocol</stringProp>
            <stringProp name="Argument.value">${__P(protocol,http)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="host" elementType="Argument">
            <stringProp name="Argument.name">host</stringProp>
            <stringProp name="Argument.value">${__P(host,localhost)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="port" elementType="Argument">
            <stringProp name="Argument.name">port</stringProp>
            <stringProp name="Argument.value">${__P(port,8080)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="connectTimeoutMs" elementType="Argument">
            <stringProp name="Argument.name">connectTimeoutMs</stringProp>
            <stringProp name="Argument.value">${__P(connectTimeoutMs,3000)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="responseTimeoutMs" elementType="Argument">
            <stringProp name="Argument.name">responseTimeoutMs</stringProp>
            <stringProp name="Argument.value">${__P(responseTimeoutMs,15000)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="jmeterTestKey" elementType="Argument">
            <stringProp name="Argument.name">jmeterTestKey</stringProp>
            <stringProp name="Argument.value">${__P(jmeterTestKey,local-bid-hotpath)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="implMode" elementType="Argument">
            <stringProp name="Argument.name">implMode</stringProp>
            <stringProp name="Argument.value">${__P(implMode,redis)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="workloadType" elementType="Argument">
            <stringProp name="Argument.name">workloadType</stringProp>
            <stringProp name="Argument.value">${__P(workloadType,winner)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="usersCsv" elementType="Argument">
            <stringProp name="Argument.name">usersCsv</stringProp>
            <stringProp name="Argument.value">${__P(usersCsv,redis-bidders.csv)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="threads" elementType="Argument">
            <stringProp name="Argument.name">threads</stringProp>
            <stringProp name="Argument.value">${__P(threads,500)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="rampUpSeconds" elementType="Argument">
            <stringProp name="Argument.name">rampUpSeconds</stringProp>
            <stringProp name="Argument.value">${__P(rampUpSeconds,10)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="loops" elementType="Argument">
            <stringProp name="Argument.name">loops</stringProp>
            <stringProp name="Argument.value">${__P(loops,1)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="feedId" elementType="Argument">
            <stringProp name="Argument.name">feedId</stringProp>
            <stringProp name="Argument.value">${__P(feedId,1001)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="winnerBidStartAmount" elementType="Argument">
            <stringProp name="Argument.name">winnerBidStartAmount</stringProp>
            <stringProp name="Argument.value">${__P(winnerBidStartAmount,10100)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="bidIncrement" elementType="Argument">
            <stringProp name="Argument.name">bidIncrement</stringProp>
            <stringProp name="Argument.value">${__P(bidIncrement,100)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="fixedBidAmount" elementType="Argument">
            <stringProp name="Argument.name">fixedBidAmount</stringProp>
            <stringProp name="Argument.value">${__P(fixedBidAmount,10200)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="thinkMs" elementType="Argument">
            <stringProp name="Argument.name">thinkMs</stringProp>
            <stringProp name="Argument.value">${__P(thinkMs,0)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>

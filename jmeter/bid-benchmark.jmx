          <elementProp name="thinkRangeMs" elementType="Argument">
            <stringProp name="Argument.name">thinkRangeMs</stringProp>
            <stringProp name="Argument.value">${__P(thinkRangeMs,0)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="simpleDataWriterFile" elementType="Argument">
            <stringProp name="Argument.name">simpleDataWriterFile</stringProp>
            <stringProp name="Argument.value">${__P(simpleDataWriterFile,)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>
      <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement" testname="HTTP Request Defaults">
        <stringProp name="HTTPSampler.connect_timeout">${connectTimeoutMs}</stringProp>
        <stringProp name="HTTPSampler.response_timeout">${responseTimeoutMs}</stringProp>
        <stringProp name="HTTPSampler.domain">${host}</stringProp>
        <stringProp name="HTTPSampler.port">${port}</stringProp>
        <stringProp name="HTTPSampler.protocol">${protocol}</stringProp>
        <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
          <collectionProp name="Arguments.arguments"/>
        </elementProp>
        <stringProp name="HTTPSampler.implementation"></stringProp>
      </ConfigTestElement>
      <hashTree/>
      <CookieManager guiclass="CookiePanel" testclass="CookieManager" testname="HTTP Cookie Manager">
        <collectionProp name="CookieManager.cookies"/>
        <boolProp name="CookieManager.clearEachIteration">false</boolProp>
        <boolProp name="CookieManager.controlledByThreadGroup">false</boolProp>
      </CookieManager>
      <hashTree/>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="HOT_PATH_ONLY">
        <stringProp name="ThreadGroup.num_threads">${threads}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${rampUpSeconds}</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">${loops}</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="Bidder CSV">
          <stringProp name="delimiter">,</stringProp>
          <stringProp name="fileEncoding">UTF-8</stringProp>
          <stringProp name="filename">${__groovy(new File(org.apache.jmeter.services.FileServer.getFileServer().getBaseDir(), vars.get(&apos;usersCsv&apos;)).path)}</stringProp>
          <boolProp name="ignoreFirstLine">true</boolProp>
          <boolProp name="quotedData">false</boolProp>
          <boolProp name="recycle">false</boolProp>
          <stringProp name="shareMode">shareMode.all</stringProp>
          <boolProp name="stopThread">true</boolProp>
          <stringProp name="variableNames">email,password</stringProp>
        </CSVDataSet>
        <hashTree/>
        <CounterConfig guiclass="CounterConfigGui" testclass="CounterConfig" testname="Global Bid Sequence">
          <stringProp name="CounterConfig.start">1</stringProp>
          <stringProp name="CounterConfig.end"></stringProp>
          <stringProp name="CounterConfig.incr">1</stringProp>
          <stringProp name="CounterConfig.name">globalBidSeq</stringProp>
          <stringProp name="CounterConfig.format"></stringProp>
          <boolProp name="CounterConfig.per_user">false</boolProp>
        </CounterConfig>
        <hashTree/>
        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer" testname="Client Think Time">
          <stringProp name="ConstantTimer.delay">${thinkMs}</stringProp>
          <stringProp name="RandomTimer.range">${thinkRangeMs}</stringProp>
        </UniformRandomTimer>
        <hashTree/>
        <TransactionController guiclass="TransactionControllerGui" testclass="TransactionController" testname="BID HOT PATH | POST ONLY">
          <boolProp name="TransactionController.parent">true</boolProp>
          <boolProp name="TransactionController.includeTimers">false</boolProp>
        </TransactionController>
        <hashTree>
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Place Bid">
            <stringProp name="HTTPSampler.path">${bidPath}</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <stringProp name="HTTPSampler.method">POST</stringProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{&quot;transactionFeedId&quot;: ${feedId}, &quot;bidAmount&quot;: ${bidAmount}}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
          </HTTPSamplerProxy>
          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Prepare Request" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">def email = vars.get(&apos;email&apos;)
if (!email) {
    throw new IllegalStateException(&apos;CSV email is required for bypass bid benchmarking&apos;)
}
vars.put(&apos;authToken&apos;, email)

def impl = (vars.get(&apos;implMode&apos;) ?: &apos;redis&apos;).trim()
switch (impl) {
    case &apos;redis&apos;:
        vars.put(&apos;bidPath&apos;, &apos;/orchestrator/bid&apos;)
        break
    case &apos;db-lock&apos;:
        vars.put(&apos;bidPath&apos;, &apos;/orchestrator/bid/db-lock&apos;)
        break
    default:
        throw new IllegalArgumentException(&apos;Unsupported implMode: &apos; + impl)
}

def workload = (vars.get(&apos;workloadType&apos;) ?: &apos;winner&apos;).trim()
long seq = (vars.get(&apos;globalBidSeq&apos;) ?: &apos;1&apos;) as long
long winnerBase = (vars.get(&apos;winnerBidStartAmount&apos;) ?: &apos;0&apos;) as long
long step = (vars.get(&apos;bidIncrement&apos;) ?: &apos;100&apos;) as long
long fixed = (vars.get(&apos;fixedBidAmount&apos;) ?: &apos;0&apos;) as long
long amount
switch (workload) {
    case &apos;winner&apos;:
        amount = winnerBase + ((seq - 1L) * step)
        break
    case &apos;loser&apos;:
        amount = fixed
        break
    case &apos;mixed&apos;:
        amount = (seq % 10L == 0L) ? (winnerBase + (((seq / 10L) - 1L) * step)) : fixed
        break
    default:
        throw new IllegalArgumentException(&apos;Unsupported workloadType: &apos; + workload)
}
vars.put(&apos;bidAmount&apos;, String.valueOf(amount))
vars.put(&apos;benchmarkCase&apos;, impl + &apos;-&apos; + workload)</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
            </JSR223PreProcessor>
            <hashTree/>
            <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="Bid Headers" enabled="true">
              <collectionProp name="HeaderManager.headers">
                <elementProp name="Content-Type" elementType="Header">
                  <stringProp name="Header.name">Content-Type</stringProp>
                  <stringProp name="Header.value">application/json</stringProp>
                </elementProp>
                <elementProp name="Accept" elementType="Header">
                  <stringProp name="Header.name">Accept</stringProp>
                  <stringProp name="Header.value">application/json</stringProp>
                </elementProp>
                <elementProp name="Authorization" elementType="Header">
                  <stringProp name="Header.name">Authorization</stringProp>
                  <stringProp name="Header.value">Bearer ${authToken}</stringProp>
                </elementProp>
                <elementProp name="X-JMeter-Test-Key" elementType="Header">
                  <stringProp name="Header.name">X-JMeter-Test-Key</stringProp>
                  <stringProp name="Header.value">${jmeterTestKey}</stringProp>
                </elementProp>
                <elementProp name="X-Benchmark-Case" elementType="Header">
                  <stringProp name="Header.name">X-Benchmark-Case</stringProp>
                  <stringProp name="Header.value">${benchmarkCase}</stringProp>
                </elementProp>
              </collectionProp>
            </HeaderManager>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Classify Response" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper

def body = prev.getResponseDataAsString()
if (!body) {
    prev.setSuccessful(false)
    prev.setResponseMessage(&apos;Empty response body&apos;)
    return
}

try {
    def parsed = new JsonSlurper().parseText(body)
    def status = parsed?.statusCode?.toString() ?: &apos;&apos;
    if (!status) {
        prev.setSuccessful(false)
        prev.setResponseMessage(&apos;Missing application statusCode&apos;)
        return
    }
    vars.put(&apos;appStatusCode&apos;, status)
    prev.setResponseCode(status)
    prev.setSampleLabel(prev.getSampleLabel() + &apos; [&apos; + vars.get(&apos;benchmarkCase&apos;) + &apos;] [app=&apos; + status + &apos;]&apos;)
} catch (Exception e) {
    prev.setSuccessful(false)
    prev.setResponseMessage(&apos;Response parse failure: &apos; + e.getMessage())
}</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>
        </hashTree>
      </hashTree>
      <ResultCollector guiclass="SummaryReport" testclass="ResultCollector" testname="Summary Report">
